generator client {
  provider = "prisma-client"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  CHECKING
  SAVINGS
}

enum TransactionType {
  WITHDRAWAL
  TRANSFER_SENT
  TRANSFER_RECEIVED
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String?
  password  String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  accounts Account[]
}

model Account {
  id             String      @id @default(uuid())
  holder         String
  type           AccountType
  balanceInCents Int
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relation to User
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  // Relations
  transactions        Transaction[] @relation("AccountTransactions")
  relatedTransactions Transaction[] @relation("RelatedTransactions")
}

model Transaction {
  id               String          @id @default(uuid())
  accountId        String
  type             TransactionType
  amountInCents    Int
  feeInCents       Int
  balanceAfter     Int
  relatedAccountId String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // Relations
  account        Account  @relation("AccountTransactions", fields: [accountId], references: [id])
  relatedAccount Account? @relation("RelatedTransactions", fields: [relatedAccountId], references: [id])
}
